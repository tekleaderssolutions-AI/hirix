# App
APP_NAME=Hirix Recruitment API
DEBUG=False

# Database — replace with your actual PostgreSQL credentials
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hirix_db

# JWT — generate a strong random secret for production
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth — get from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
